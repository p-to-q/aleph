# Optional: URL of the Aleph live-search backend (search/server.py).
# Leave unset for local dev (defaults to http://localhost:8000/search).
# On Vercel, local mlx is shown as unavailable unless this points at a
# deployed or tunneled Apple Silicon search service, e.g.:
#   NEXT_PUBLIC_SEARCH_API=https://aleph-search.trycloudflare.com/search
# If unreachable, the UI degrades gracefully (precomputed examples still work).
NEXT_PUBLIC_SEARCH_API=

# Optional: AlephRun-compatible HTTP API. Defaults to the same-origin
# Next.js mock route at /api/search, which works on Vercel.
NEXT_PUBLIC_CLAUDE_API=

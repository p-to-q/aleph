# Optional: URL of the Aleph live-search backend (search/server.py).
# Leave unset for local dev (defaults to http://localhost:8000/search).
# On Vercel, local mlx is red/unavailable unless this points at a deployed or
# tunneled Apple Silicon search service. Once configured, the browser checks
# the matching /health endpoint and turns local mlx green only when reachable.
# Example:
#   NEXT_PUBLIC_SEARCH_API=https://aleph-search.trycloudflare.com/search
# If unreachable, the UI degrades gracefully (precomputed examples still work).
NEXT_PUBLIC_SEARCH_API=

# Optional: AlephRun-compatible HTTP API. Defaults to the same-origin
# Next.js route at /api/search.
NEXT_PUBLIC_CLAUDE_API=

# Optional: server-side hosted black-box model adapter for /api/search.
# These values must stay server-only; do not prefix the key/base URL with
# NEXT_PUBLIC_. The adapter expects an OpenAI-compatible /chat/completions API.
# If unset, /api/search falls back to a clearly marked mock run.
# Public hosted defaults:
#   primary URL: https://zapi.aicc0.com/v1
#   fallback URL: https://jiuuij.de5.net/v1
#   primary model: deepseek-v4-pro
#   fallback model: qwen3.6-27b-nothinking
# The keys must be configured as server-side environment variables in the
# deployment platform, never committed to this file.
# ALEPH_CUSTOM_API_BASE_URL=https://zapi.aicc0.com/v1
# ALEPH_CUSTOM_API_KEY=
# ALEPH_CUSTOM_API_FALLBACK_BASE_URL=https://jiuuij.de5.net/v1
# ALEPH_CUSTOM_API_FALLBACK_KEY=
# ALEPH_CUSTOM_API_MODEL=deepseek-v4-pro
# ALEPH_CUSTOM_API_FALLBACK_MODEL=qwen3.6-27b-nothinking
